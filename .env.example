# Cadence — Root .env Template
# Copy this to .env and fill in your secrets. Do NOT commit the actual .env file.

# ─── API ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# The cloud database connection string (Supabase URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# The frontend URL — used for CORS on the backend
ALLOW_ORIGINS=https://your-web-domain.com

# ─── Web (Next.js) ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Point to your deployed API URL in production
NEXT_PUBLIC_API_URL=https://your-api-domain.com
